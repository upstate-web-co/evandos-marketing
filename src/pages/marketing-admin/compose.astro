---
import MarketingAdminLayout from '../../layouts/MarketingAdminLayout.astro'
import PostComposer from '../../components/marketing-admin/PostComposer'
---
<MarketingAdminLayout title="Compose">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Compose Post</h1>
    <p class="text-sm text-[#F7F4EF]/50 mt-1">
      Draft content and schedule to one or more platforms.
    </p>
  </div>

  <div class="max-w-2xl">
    <PostComposer client:load />
  </div>
</MarketingAdminLayout>
