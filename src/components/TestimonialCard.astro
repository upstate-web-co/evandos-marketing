---
interface Props {
  quote: string
  name: string
  role?: string
  company?: string
}

const { quote, name, role, company } = Astro.props
const initial = name.charAt(0).toUpperCase()
---
<div class="bg-white rounded-xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">
  <!-- Star rating -->
  <div class="flex gap-0.5 mb-4">
    {[1,2,3,4,5].map(() => (
      <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  <p class="text-charcoal/80 leading-relaxed mb-6">"{quote}"</p>
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-rust/10 flex items-center justify-center flex-shrink-0">
      <span class="text-rust font-bold text-sm">{initial}</span>
    </div>
    <div>
      <p class="font-semibold text-sm">{name}</p>
      {(role || company) && (
        <p class="text-xs text-charcoal/50">
          {[role, company].filter(Boolean).join(', ')}
        </p>
      )}
    </div>
  </div>
</div>
