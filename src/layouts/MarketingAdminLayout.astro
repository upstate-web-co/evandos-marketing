---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
const currentPath = Astro.url.pathname

const sidebarLinks = [
  { href: '/marketing-admin', label: 'Dashboard', icon: 'home' },
  { href: '/marketing-admin/compose', label: 'Compose', icon: 'edit' },
  { href: '/marketing-admin/calendar', label: 'Calendar', icon: 'calendar' },
  { href: '/marketing-admin/seo', label: 'SEO', icon: 'search' },
  { href: '/marketing-admin/analytics', label: 'Analytics', icon: 'chart' },
  { href: '/marketing-admin/drafts', label: 'Drafts', icon: 'file' },
  { href: '/marketing-admin/blog-ideas', label: 'Blog Ideas', icon: 'lightbulb' },
  { href: '/marketing-admin/subscribers', label: 'Subscribers', icon: 'users' },
  { href: '/marketing-admin/broadcast', label: 'Broadcast', icon: 'broadcast' },
  { href: '/marketing-admin/emails', label: 'Emails', icon: 'mail' },
  { href: '/marketing-admin/tokens', label: 'Connections', icon: 'link' },
]

function isActive(href: string): boolean {
  if (href === '/marketing-admin') return currentPath === '/marketing-admin' || currentPath === '/marketing-admin/'
  return currentPath.startsWith(href)
}

const icons: Record<string, string> = {
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1',
  edit: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  search: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  file: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  lightbulb: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  users: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  link: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  mail: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  broadcast: 'M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 15.828a5 5 0 010-7.656m5.656 0a5 5 0 010 7.656M12 12h.01',
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Marketing Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#1A1814] text-[#F7F4EF] min-h-screen font-sans antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden md:flex flex-col w-56 bg-[#1A1814] border-r border-[#F7F4EF]/10 fixed inset-y-0">
        <div class="px-5 py-5 border-b border-[#F7F4EF]/10">
          <a href="/marketing-admin" class="text-sm font-bold tracking-tight text-[#B85C38]">
            UWC Admin
          </a>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1" aria-label="Admin navigation">
          {sidebarLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              class:list={[
                'flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors',
                isActive(href)
                  ? 'bg-[#B85C38] text-white font-medium'
                  : 'text-[#F7F4EF]/60 hover:text-[#F7F4EF] hover:bg-[#F7F4EF]/5',
              ]}
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons[icon]} />
              </svg>
              {label}
            </a>
          ))}
        </nav>
        <div class="px-5 py-4 border-t border-[#F7F4EF]/10 space-y-2">
          <a href="/api/marketing-admin/auth-logout" class="block text-xs text-[#F7F4EF]/40 hover:text-[#F7F4EF]/70 transition-colors">
            Log Out
          </a>
          <a href="/" class="block text-xs text-[#F7F4EF]/40 hover:text-[#F7F4EF]/70 transition-colors">
            &larr; Back to site
          </a>
        </div>
      </aside>

      <!-- Mobile header -->
      <div class="md:hidden fixed top-0 inset-x-0 z-50 bg-[#1A1814] border-b border-[#F7F4EF]/10">
        <div class="flex items-center justify-between px-4 py-3">
          <a href="/marketing-admin" class="text-sm font-bold text-[#B85C38]">UWC Admin</a>
          <button id="admin-menu-btn" class="p-2 -mr-2" aria-label="Toggle menu" aria-expanded="false">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <div id="admin-mobile-menu" class="hidden border-t border-[#F7F4EF]/10 px-3 py-2 space-y-1">
          {sidebarLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              class:list={[
                'flex items-center gap-3 px-3 py-2 rounded-lg text-sm',
                isActive(href)
                  ? 'bg-[#B85C38] text-white font-medium'
                  : 'text-[#F7F4EF]/60',
              ]}
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icons[icon]} />
              </svg>
              {label}
            </a>
          ))}
          <a href="/api/marketing-admin/auth-logout" class="block px-3 py-2 text-xs text-[#F7F4EF]/40">Log Out</a>
          <a href="/" class="block px-3 py-2 text-xs text-[#F7F4EF]/40">&larr; Back to site</a>
        </div>
      </div>

      <!-- Main content -->
      <main class="flex-1 md:ml-56 min-h-screen">
        <div class="max-w-5xl mx-auto px-6 py-8 md:py-8 mt-14 md:mt-0">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const btn = document.getElementById('admin-menu-btn')
      const menu = document.getElementById('admin-mobile-menu')
      btn?.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true'
        btn.setAttribute('aria-expanded', String(!expanded))
        menu?.classList.toggle('hidden')
      })
    </script>
  </body>
</html>
